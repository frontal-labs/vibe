{
  "name": "@frontal-labs/vibe-cli",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "vibe": "./bin/vibe.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "bin",
    "scripts",
    "dist"
  ],
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:types": "tsd",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "vibe/generators": "workspace:*",
    "chokidar": "^4.0.0",
    "commander": "^12.1.0",
    "vibe/build": "workspace:*",
    "vibe/errors": "workspace:*"
  },
  "devDependencies": {
    "tsd": "^0.31.2",
    "vitest": "^3.0.0",
    "vite": "^6.0.0"
  },
  "tsd": {
    "directory": "type-tests"
  }
}
