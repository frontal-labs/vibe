{
	"$schema": "https://docs.renovatebot.com/renovate-schema.json",
	"extends": [
		"config:recommended",
		":semanticCommits",
		":semanticCommitTypeAll(chore)",
		":separateMajorMinor",
		"group:monorepos",
		"schedule:weekly"
	],
	"labels": ["dependencies"],
	"rebaseWhen": "conflicted",
	"dependencyDashboard": true,
	"dependencyDashboardTitle": "Dependency Dashboard",
	"vulnerabilityAlerts": {
		"enabled": true,
		"labels": ["security"]
	},
	"packageRules": [
		{
			"description": "GitHub Actions: update weekly",
			"matchManagers": ["github-actions"],
			"groupName": "GitHub Actions",
			"groupSlug": "github-actions",
			"addLabels": ["github-actions", "ci"],
			"semanticCommitType": "chore",
			"pin": {
				"enabled": true,
				"automerge": true
			}
		},
		{
			"description": "npm dependencies",
			"matchManagers": ["npm"],
			"groupName": "npm dependencies",
			"groupSlug": "npm",
			"addLabels": ["npm", "javascript"],
			"semanticCommitType": "chore",
			"schedule": ["before 9am on Monday"]
		},
		{
			"description": "Auto-merge patch updates",
			"matchUpdateTypes": ["patch"],
			"automerge": true,
			"automergeType": "pr",
			"platformAutomerge": true
		}
	],
	"lockFileMaintenance": {
		"enabled": true,
		"schedule": ["before 9am on Monday"]
	},
	"postUpdateOptions": ["npmDedupe"],
	"prBodyColumns": [
		"Package",
		"Type",
		"Change",
		"Age",
		"Adoption",
		"Passing",
		"Confidence"
	],
	"prFooter": "This PR was auto-generated by Renovate.",
	"timezone": "UTC"
}
