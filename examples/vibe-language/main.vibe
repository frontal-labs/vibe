config { name "vibe-language" ; provider anthropic }

/// Look up an order's status by id.
tool GetOrder(orderId: string) -> string { return `shipped: ${orderId}` }

model Fast { id claude-haiku-4-5 ; effort low }

agent Support {
  model claude-opus-4-8
  system "You are a concise support agent. Use tools before guessing."
  use GetOrder
}
