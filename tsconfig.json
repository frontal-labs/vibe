      "@vibe/logger/*": ["./packages/logger/src/*"],
      "@vibe/memory": ["./packages/memory/src"],
      "@vibe/memory/*": ["./packages/memory/src/*"],
      "@vibe/model": ["./packages/model/src"],
      "@vibe/model/*": ["./packages/model/src/*"],
      "@vibe/plugin": ["./packages/plugin/src"],
      "@vibe/plugin/*": ["./packages/plugin/src/*"],
      "@vibe/runtime": ["./packages/runtime/src"],
      "@vibe/runtime/*": ["./packages/runtime/src/*"],
      "@vibe/shared": ["./packages/shared/src"],
      "@vibe/shared/*": ["./packages/shared/src/*"],
      "@vibe/tools": ["./packages/tools/src"],
      "@vibe/tools/*": ["./packages/tools/src/*"],
      "@vibe/tracing": ["./packages/tracing/src"],
      "@vibe/tracing/*": ["./packages/tracing/src/*"],
      "@vibe/mcp-server": ["./packages/mcp-server/src"],
      "@vibe/mcp-server/*": ["./packages/mcp-server/src/*"]
    }
  },
  "exclude": ["node_modules", "dist", "build", ".next", "coverage", "target"]
