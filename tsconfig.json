{
  "extends": "./packages/typescript-config/tsconfig.base.json",
  "compilerOptions": {
    "paths": {
      "@vibe/adapters": ["./packages/adapters/src"],
      "@vibe/adapters/*": ["./packages/adapters/src/*"],
      "@vibe/agent": ["./packages/agent/src"],
      "@vibe/agent/*": ["./packages/agent/src/*"],
      "@vibe/build": ["./packages/build/src"],
      "@vibe/build/*": ["./packages/build/src/*"],
      "@vibe/config": ["./packages/config/src"],
      "@vibe/config/*": ["./packages/config/src/*"],
      "@vibe/core": ["./packages/core/src"],
      "@vibe/core/*": ["./packages/core/src/*"],
      "@vibe/deploy": ["./packages/deploy/src"],
      "@vibe/deploy/*": ["./packages/deploy/src/*"],
      "@vibe/devtools": ["./packages/devtools/src"],
      "@vibe/devtools/*": ["./packages/devtools/src/*"],
      "@vibe/di": ["./packages/di/src"],
      "@vibe/di/*": ["./packages/di/src/*"],
      "@vibe/errors": ["./packages/errors/src"],
      "@vibe/errors/*": ["./packages/errors/src/*"],
      "@vibe/evals": ["./packages/evals/src"],
      "@vibe/evals/*": ["./packages/evals/src/*"],
      "@vibe/lifecycle": ["./packages/lifecycle/src"],
