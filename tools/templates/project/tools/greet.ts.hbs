import { defineTool } from "vibe/tools"
import { z } from "zod"

// A tool is any Standard Schema (Zod by default) + a typed handler.
export default defineTool({
  name: "greet",
  description: "Greet someone by name.",
  schema: z.object({ name: z.string().describe("Who to greet") }),
  execute: ({ name }) => `Hello, ${name}!`, // `name` is typed as string
})
