config { name "{{name}}" ; provider anthropic }

/// Look up an order's status.
tool GetOrder(orderId: string) -> string { return `shipped: ${orderId}` }

model Fast { id claude-haiku-4-5 ; effort low }

agent Triage {
  model Fast
  system "Classify the request and route it."
  use GetOrder
}

agent Support {
  model claude-opus-4-8
  system "You are a concise support agent. Delegate triage when useful."
  use GetOrder
  use Triage
}
