{
  "name": "@frontal-labs/vibe",
  "version": "0.0.0",
  "type": "module",
  "description": "The Vibe framework barrel — import from `@frontal-labs/vibe` and `@frontal-labs/vibe/*` instead of `vibe/*`.",
  "keywords": [
    "ai",
    "agents",
    "agent-framework",
    "llm",
    "anthropic",
    "openai",
    "tools",
    "tool-calling",
    "mcp",
    "typescript",
    "frontal",
    "vibe"
  ],
  "homepage": "https://github.com/vibe-lang/vibe#readme",
  "bugs": {
    "url": "https://github.com/vibe-lang/vibe/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/frontal-labs/vibe.git",
    "directory": "vibe"
  },
  "license": "Apache-2.0",
  "author": "Frontal (https://frontal.dev)",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./agent": {
      "import": "./dist/agent.js",
      "require": "./dist/agent.cjs",
      "types": "./dist/agent.d.ts"
    },
    "./tools": {
      "import": "./dist/tools.js",
      "require": "./dist/tools.cjs",
      "types": "./dist/tools.d.ts"
    },
    "./model": {
      "import": "./dist/model.js",
      "require": "./dist/model.cjs",
      "types": "./dist/model.d.ts"
    },
    "./memory": {
      "import": "./dist/memory.js",
      "require": "./dist/memory.cjs",
      "types": "./dist/memory.d.ts"
    },
    "./core": {
      "import": "./dist/core.js",
      "require": "./dist/core.cjs",
      "types": "./dist/core.d.ts"
    },
    "./errors": {
      "import": "./dist/errors.js",
      "require": "./dist/errors.cjs",
      "types": "./dist/errors.d.ts"
    },
    "./logger": {
      "import": "./dist/logger.js",
      "require": "./dist/logger.cjs",
      "types": "./dist/logger.d.ts"
    },
    "./runtime": {
      "import": "./dist/runtime.js",
      "require": "./dist/runtime.cjs",
      "types": "./dist/runtime.d.ts"
    },
    "./plugin": {
      "import": "./dist/plugin.js",
      "require": "./dist/plugin.cjs",
      "types": "./dist/plugin.d.ts"
    },
    "./di": {
      "import": "./dist/di.js",
      "require": "./dist/di.cjs",
      "types": "./dist/di.d.ts"
    },
    "./adapters": {
      "import": "./dist/adapters.js",
      "require": "./dist/adapters.cjs",
      "types": "./dist/adapters.d.ts"
    },
    "./tracing": {
      "import": "./dist/tracing.js",
      "require": "./dist/tracing.cjs",
      "types": "./dist/tracing.d.ts"
    },
    "./evals": {
      "import": "./dist/evals.js",
      "require": "./dist/evals.cjs",
      "types": "./dist/evals.d.ts"
    },
    "./deploy": {
      "import": "./dist/deploy.js",
      "require": "./dist/deploy.cjs",
      "types": "./dist/deploy.d.ts"
    },
    "./devtools": {
      "import": "./dist/devtools.js",
      "require": "./dist/devtools.cjs",
      "types": "./dist/devtools.d.ts"
    },
    "./config": {
      "import": "./dist/config.js",
      "require": "./dist/config.cjs",
      "types": "./dist/config.d.ts"
    },
    "./skills": {
      "import": "./dist/skills.js",
      "require": "./dist/skills.cjs",
      "types": "./dist/skills.d.ts"
    },
    "./workflows": {
      "import": "./dist/workflows.js",
      "require": "./dist/workflows.cjs",
      "types": "./dist/workflows.d.ts"
    },
    "./ontology": {
      "import": "./dist/ontology.js",
      "require": "./dist/ontology.cjs",
      "types": "./dist/ontology.d.ts"
    },
    "./governance": {
      "import": "./dist/governance.js",
      "require": "./dist/governance.cjs",
      "types": "./dist/governance.d.ts"
    },
    "./security": {
      "import": "./dist/security.js",
      "require": "./dist/security.cjs",
      "types": "./dist/security.d.ts"
    },
    "./observability": {
      "import": "./dist/observability.js",
      "require": "./dist/observability.cjs",
      "types": "./dist/observability.d.ts"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:types": "tsd",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "vibe/agent": "workspace:*",
    "vibe/tools": "workspace:*",
    "vibe/model": "workspace:*",
    "vibe/memory": "workspace:*",
    "vibe/core": "workspace:*",
    "vibe/errors": "workspace:*",
    "vibe/logger": "workspace:*",
    "vibe/runtime": "workspace:*",
    "vibe/plugin": "workspace:*",
    "vibe/di": "workspace:*",
    "vibe/adapters": "workspace:*",
    "vibe/tracing": "workspace:*",
    "vibe/evals": "workspace:*",
    "vibe/deploy": "workspace:*",
    "vibe/devtools": "workspace:*",
    "vibe/config": "workspace:*",
    "vibe/skills": "workspace:*",
    "vibe/workflows": "workspace:*",
    "vibe/ontology": "workspace:*",
    "vibe/governance": "workspace:*",
    "vibe/security": "workspace:*",
    "vibe/observability": "workspace:*"
  },
  "devDependencies": {
    "tsd": "^0.31.2",
    "vitest": "^2.1.8",
    "vite": "^6.0.0"
  },
  "tsd": {
    "directory": "type-tests"
  }
}
