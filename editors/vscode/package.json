{
  "name": "vibe-vscode",
  "displayName": "Vibe",
  "description": "Syntax highlighting and language support for the Vibe agent language.",
  "version": "0.0.0",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "main": "./client/extension.js",
  "activationEvents": [
    "onLanguage:vibe"
  ],
  "contributes": {
    "languages": [
      {
        "id": "vibe",
        "aliases": [
          "Vibe"
        ],
        "extensions": [
          ".vibe"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "vibe",
        "scopeName": "source.vibe",
        "path": "./syntaxes/vibe.tmLanguage.json"
      }
    ]
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}
