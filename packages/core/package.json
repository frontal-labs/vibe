{
  "name": "vibe/core",
  "version": "0.0.1",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly",
    "dev": "vite build --watch",
    "test": "vitest run --config vite.config.ts",
    "test:types": "tsd",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "vibe/agent": "workspace:*",
    "vibe/config": "workspace:*",
    "vibe/di": "workspace:*",
    "vibe/errors": "workspace:*",
    "vibe/governance": "workspace:*",
    "vibe/lifecycle": "workspace:*",
    "vibe/logger": "workspace:*",
    "vibe/memory": "workspace:*",
    "vibe/model": "workspace:*",
    "vibe/observability": "workspace:*",
    "vibe/ontology": "workspace:*",
    "vibe/plugin": "workspace:*",
    "vibe/runtime": "workspace:*",
    "vibe/security": "workspace:*",
    "vibe/shared": "workspace:*",
    "vibe/skills": "workspace:*",
    "vibe/tools": "workspace:*",
    "vibe/workflows": "workspace:*"
  },
  "tsd": {
    "directory": "type-tests"
  },
  "devDependencies": {
    "tsd": "^0.31.2",
    "zod": "^4.4.3",
    "vite": "^6.0.0"
  },
  "private": true
}
